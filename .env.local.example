# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=-100...

# Price relay (optional — for environments where Bybit is blocked)
# PRICE_API_BASE_URL=https://your-relay-domain.com

# Secret sent by TradingView in x-webhook-secret header or ?secret= query param
# WEBHOOK_SECRET=

# CRON_SECRET=  # Must match Vercel cron secret for scheduled routes
# Admin/debug routes accept any configured CRON_SECRET / WEBHOOK_SECRET / EXEC_WEBHOOK_SECRET

# Max stop distance as fraction of entry price (default 0.08 = 8%)
# MAX_STOP_DIST_PCT=0.08

# ── BTC 12h range filter REMOVED 2026-04-09 ──
# The BTC_RANGE_FILTER_* env vars are no longer read by any code path.
# The 15-50% SHORT band was proven value-destructive (-0.244R on 2026 hold-out)
# and the runtime env toggle proved unreliable. Safe to delete from Vercel.
# Ref: brain/oos_validation_2026-04-08.md
# VOL_RATIO_MIN=0.5

# ── Bear regime Telegram filter (from 11K signal backtest) ──
# Bear bb_width 0.08-0.12 = PF 2.01; above 0.12 = PF 0.74-1.10 (losing)
# BEAR_BB_WIDTH_MAX=0.12
# Bear vol_ratio 2.0-2.5 bucket = PF 0.88 (losing dead zone)
# BEAR_VOL_DEAD_ZONE_LOW=2.0
# BEAR_VOL_DEAD_ZONE_HIGH=2.5

# ── Risk management (all optional, sensible defaults) ──
# ACCOUNT_VALUE_USD=1500
# INITIAL_ACCOUNT_VALUE_USD=1500
# DAILY_LOSS_LIMIT_R=-5
# MAX_CONCURRENT_POSITIONS=10
# PORTFOLIO_HEAT_LIMIT_PCT=0.10
# MAX_RISK_PER_TRADE_PCT=0.02
# BURST_THRESHOLD=5
# BURST_RISK_PCT=0.01

# Execution Engine Webhook (optional — only set if running the VPS execution engine)
# EXEC_WEBHOOK_URL=http://YOUR_VULTR_IP:3001/webhook/signal
# EXEC_WEBHOOK_SECRET=your-shared-secret
