# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=-100...

# Price relay (optional — for environments where Bybit is blocked)
# PRICE_API_BASE_URL=https://your-relay-domain.com

# Secret sent by TradingView in x-webhook-secret header or ?secret= query param
# WEBHOOK_SECRET=

# CRON_SECRET=  # Must match Vercel cron secret for scheduled routes

# Max stop distance as fraction of entry price (default 0.08 = 8%)
# MAX_STOP_DIST_PCT=0.08
